@startuml
actor "Администратор" as Admin

rectangle "Управление на занаяти" {
  usecase "Добавяне на нов занаят" as UC1
  usecase "Редактиране на занаят" as UC2
  usecase "Изтриване (деактивиране) на занаят" as UC3
  usecase "Добавяне на превод" as UC4
  usecase "Промяна на локация (lat/lng)" as UC5
}

Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC4
Admin --> UC5

note right of UC1 : Въвежда име, описание,\nснимка, координати
note right of UC4 : На български и английски
@enduml